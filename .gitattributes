# ── Line-ending normalization (Windows compatibility) ──────────────────────
# Default: normalize text to LF in the repo, auto-convert on checkout per-OS.
* text=auto

# Files that MUST be LF even when checked out on Windows — CRLF here breaks
# execution inside Linux containers (shebangs, entrypoints, parsing).
*.py    text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.csv   text eol=lf
*.md    text eol=lf
Dockerfile      text eol=lf
.dockerignore   text eol=lf
Makefile        text eol=lf

# Windows-native helper scripts keep CRLF.
*.ps1   text eol=crlf
*.bat   text eol=crlf

# ── Git LFS ─────────────────────────────────────────────────────────────────
