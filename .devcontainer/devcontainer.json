{
  "name": "MLOps End2End (Python 3.12)",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "features": {
    // Lets you run `docker` / `docker compose` against the host Docker Desktop
    // from inside the dev container (Windows/macOS/Linux).
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {}
  },
  // Editable install with dev extras, into the container's system Python.
  "postCreateCommand": "pip install uv && uv pip install --system -e '.[dev]'",
  // Dagster (3000), MLflow (5000), Gradio (7860), FastAPI (8000)
  "forwardPorts": [3000, 5000, 7860, 8000],
  "portsAttributes": {
    "3000": { "label": "Dagster" },
    "5000": { "label": "MLflow" },
    "7860": { "label": "Gradio" },
    "8000": { "label": "FastAPI" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "files.eol": "\n"
      }
    }
  }
}
